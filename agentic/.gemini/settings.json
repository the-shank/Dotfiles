{
  "general": {
    "preferredEditor": "neovim",
    "previewFeatures": true,
    "vimMode": false,
    "enableNotifications": true,
    "sessionRetention": {
      "warningAcknowledged": true,
      "enabled": true,
      "maxAge": "30d"
    },
    "plan": {
      "directory": "./plans"
    }
  },
  "security": {
    "auth": {
      "selectedType": "oauth-personal"
    }
  },
  "ui": {
    "theme": "Google Code",
    "hideBanner": true,
    "footer": {
      "hideModelInfo": false,
      "hideContextPercentage": false
    }
  },
  "experimental": {
    "plan": true
  },
  "model": {
    "compressionThreshold": 0.6
  }
}